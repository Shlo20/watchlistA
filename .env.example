# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/watchlist

# JWT
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 days — non-technical mobile users should stay logged in

# Brevo (transactional email) for email-to-SMS gateways
# Sign up at https://www.brevo.com, verify a sender email, generate an API key
# in Settings → SMTP & API → API keys
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
SMS_ENABLED=true

# Deprecated — kept for backwards compat with local dev only
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# App
ENVIRONMENT=development

# Scheduler settings — APScheduler runs daily digest + auto-archive
SCHEDULER_ENABLED=true
DIGEST_HOUR=6
ARCHIVE_HOUR=3
