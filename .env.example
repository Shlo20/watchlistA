# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rmb_restock

# JWT
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 days — non-technical mobile users should stay logged in

# Notifications (Resend for sending emails -> carrier SMS gateways)
RESEND_API_KEY=re_xxxxxxxxxxxx
NOTIFICATION_FROM_EMAIL=restock@yourdomain.com

# App
ENVIRONMENT=development
