# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/watchlist

# JWT
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars-long
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 days — non-technical mobile users should stay logged in

# Gmail SMTP for email-to-SMS gateways (free, no signup beyond Google account)
# 1. Enable 2-Step Verification on your Google account
# 2. Create an App Password at https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password below (spaces are fine, will be stripped)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
SMS_ENABLED=true

# App
ENVIRONMENT=development

# Scheduler settings — APScheduler runs daily digest + auto-archive
SCHEDULER_ENABLED=true
DIGEST_HOUR=6
ARCHIVE_HOUR=3
